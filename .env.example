# ============================================================
# Auto-GPT Startup Operations Platform — Environment Template
# Copy this file to .env and fill in your actual credentials.
# ============================================================

# ----------------------------------------------------------
# OpenAI (required)
# ----------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ----------------------------------------------------------
# GitHub (engineering agent)
# ----------------------------------------------------------
GITHUB_TOKEN=ghp_...
# Optional: push new repos to an org instead of your personal account
GITHUB_ORG=

# ----------------------------------------------------------
# Render (deployment)
# ----------------------------------------------------------
RENDER_API_KEY=rnd_...
# Found in your Render dashboard → Account Settings → Owner ID
RENDER_OWNER_ID=

# ----------------------------------------------------------
# PostgreSQL / Render Postgres
# ----------------------------------------------------------
# e.g. postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ----------------------------------------------------------
# Twitter / X  (twitter agent)
# ----------------------------------------------------------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ----------------------------------------------------------
# Meta Ads  (meta_ads agent)
# ----------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# Format: act_<numeric-id>  (do NOT include the "act_" prefix here)
META_AD_ACCOUNT_ID=

# ----------------------------------------------------------
# Slack  (slack agent + task notifications)
# ----------------------------------------------------------
# Incoming Webhook URL — paste from Slack App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Bot token (xoxb-…) — needed for posting to specific channels
SLACK_BOT_TOKEN=xoxb-...
# Default channel to post to (without #), e.g. general
SLACK_DEFAULT_CHANNEL=general

# ----------------------------------------------------------
# Email  (email agent + analytics report delivery)
# ----------------------------------------------------------
# Option 1: SendGrid (recommended for production)
EMAIL_SENDGRID_API_KEY=SG.…
# Option 2: SMTP (e.g. Gmail with an app password)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=you@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
# Sender address used in both SendGrid and SMTP modes
EMAIL_FROM_ADDRESS=noreply@yourstartup.com
# Default recipient for reports and compose_and_send when no "to" is specified
EMAIL_DEFAULT_TO=founders@yourstartup.com

# ----------------------------------------------------------
# Scheduler
# ----------------------------------------------------------
# Set to false to disable the background task scheduler
SCHEDULER_ENABLED=true

# ----------------------------------------------------------
# Web UI  (FastAPI chat server)
# ----------------------------------------------------------
# Port the web chat server listens on (default: 8000)
WEB_PORT=8000
# Optional secret used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=
# Optional API key to protect the web API endpoints (X-API-Key header).
# Leave blank to disable authentication.
WEB_API_KEY=

# ----------------------------------------------------------
# General
# ----------------------------------------------------------
VERBOSE=false
MAX_ITERATIONS=10

# ----------------------------------------------------------
# Customer Support Agent
# ----------------------------------------------------------
# (Uses DATABASE_URL for the KB/ticket tables, SLACK_* and EMAIL_* for escalation)
# No additional env vars required.

# ----------------------------------------------------------
# Telegram  (telegram agent)
# ----------------------------------------------------------
# Bot API token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Default chat / channel ID for broadcasts (e.g. @mychannel or numeric ID)
TELEGRAM_DEFAULT_CHAT_ID=

# ----------------------------------------------------------
# YouTube  (youtube agent)
# ----------------------------------------------------------
# Google Cloud API key with YouTube Data API v3 enabled
YOUTUBE_API_KEY=
# Your YouTube channel ID (e.g. UCxxxxxxxxxxxxxxxxxxxxxxxx)
YOUTUBE_CHANNEL_ID=

# ----------------------------------------------------------
# Google Custom Search  (google agent)
# ----------------------------------------------------------
# Google Cloud API key with Custom Search JSON API enabled
GOOGLE_API_KEY=
# Programmable Search Engine ID (cx) from cse.google.com
GOOGLE_SEARCH_ENGINE_ID=

# ----------------------------------------------------------
# Yelp  (yelp agent)
# ----------------------------------------------------------
# Private API key from https://www.yelp.com/developers
YELP_API_KEY=

# ----------------------------------------------------------
# Pinterest  (pinterest agent)
# ----------------------------------------------------------
# OAuth 2 access token from the Pinterest developer app
PINTEREST_ACCESS_TOKEN=
# Default board ID for pin creation
PINTEREST_DEFAULT_BOARD_ID=

# ----------------------------------------------------------
# LinkedIn  (linkedin agent)
# ----------------------------------------------------------
# OAuth 2.0 access token with w_member_social, r_organization_social,
# rw_organization_admin scopes from https://www.linkedin.com/developers
LINKEDIN_ACCESS_TOKEN=
# URN of the authenticated member (e.g. urn:li:person:ABC123)
LINKEDIN_PERSON_URN=
# Numeric ID of the LinkedIn company/organization page
LINKEDIN_ORG_ID=

# ----------------------------------------------------------
# Stripe  (stripe agent)
# ----------------------------------------------------------
# Secret API key from https://dashboard.stripe.com/apikeys
# Use a restricted key in production
STRIPE_SECRET_KEY=
# ISO-4217 currency code (default: usd)
STRIPE_DEFAULT_CURRENCY=usd

# ----------------------------------------------------------
# HubSpot  (hubspot agent)
# ----------------------------------------------------------
# Private-app access token from HubSpot
# (Settings → Integrations → Private Apps)
# Requires CRM read+write scopes for contacts, deals, notes
HUBSPOT_API_KEY=
# Optional: ID of the default sales pipeline
HUBSPOT_DEFAULT_PIPELINE_ID=

# ----------------------------------------------------------
# Shopify  (shopify agent)
# ----------------------------------------------------------
# Your Shopify store domain (no https://)  e.g. my-store.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Admin API access token from the Shopify partner dashboard
# Requires read_products, read_orders, read_customers, write_price_rules
SHOPIFY_ACCESS_TOKEN=
# Default ISO-4217 currency code (default: USD)
SHOPIFY_CURRENCY=USD

# ============================================================
# Auto-GPT Startup Operations Platform — Environment Template
# Copy this file to .env and fill in your actual credentials.
# ============================================================

# ----------------------------------------------------------
# OpenAI (required)
# ----------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ----------------------------------------------------------
# GitHub (engineering agent)
# ----------------------------------------------------------
GITHUB_TOKEN=ghp_...
# Optional: push new repos to an org instead of your personal account
GITHUB_ORG=

# ----------------------------------------------------------
# Render (deployment)
# ----------------------------------------------------------
RENDER_API_KEY=rnd_...
# Found in your Render dashboard → Account Settings → Owner ID
RENDER_OWNER_ID=

# ----------------------------------------------------------
# PostgreSQL / Render Postgres
# ----------------------------------------------------------
# e.g. postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ----------------------------------------------------------
# Twitter / X  (twitter agent)
# ----------------------------------------------------------
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# ----------------------------------------------------------
# Meta Ads  (meta_ads agent)
# ----------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
# Format: act_<numeric-id>  (do NOT include the "act_" prefix here)
META_AD_ACCOUNT_ID=

# ----------------------------------------------------------
# Slack  (slack agent + task notifications)
# ----------------------------------------------------------
# Incoming Webhook URL — paste from Slack App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Bot token (xoxb-…) — needed for posting to specific channels
SLACK_BOT_TOKEN=xoxb-...
# Default channel to post to (without #), e.g. general
SLACK_DEFAULT_CHANNEL=general

# ----------------------------------------------------------
# Email  (email agent + analytics report delivery)
# ----------------------------------------------------------
# Option 1: SendGrid (recommended for production)
EMAIL_SENDGRID_API_KEY=SG.…
# Option 2: SMTP (e.g. Gmail with an app password)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=you@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
# Sender address used in both SendGrid and SMTP modes
EMAIL_FROM_ADDRESS=noreply@yourstartup.com
# Default recipient for reports and compose_and_send when no "to" is specified
EMAIL_DEFAULT_TO=founders@yourstartup.com

# ----------------------------------------------------------
# Scheduler
# ----------------------------------------------------------
# Set to false to disable the background task scheduler
SCHEDULER_ENABLED=true

# ----------------------------------------------------------
# Web UI  (FastAPI chat server)
# ----------------------------------------------------------
# Port the web chat server listens on (default: 8000)
WEB_PORT=8000
# Optional secret used to sign session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=
# Optional API key to protect the web API endpoints (X-API-Key header).
# Leave blank to disable authentication.
WEB_API_KEY=

# ----------------------------------------------------------
# General
# ----------------------------------------------------------
VERBOSE=false
MAX_ITERATIONS=10
